# taskhub/.env  — copy this file to .env and fill in real values
# NEVER commit .env to git.

# Monad Testnet HTTP RPC
RPC_URL=https://testnet-rpc.monad.xyz

# Private key of the account that deployed AgentTrust.sol (same = onlyOwner)
# Export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Paste the address Remix gives you after deployment
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Get free key from: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_YOUR_KEY_HERE
